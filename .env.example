# =============================================================================
# Fame FMS — Environment Variables Template
# Copy to .env and fill in values. Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (Docker local dev defaults)
# -----------------------------------------------------------------------------
POSTGRES_DB=fame_fms
POSTGRES_USER=fame_user
POSTGRES_PASSWORD=fame_dev_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Django core
# Generate a secure key for production:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=django-insecure-replace-this-in-production

# Set to True ONLY for local development. Must be False (or omitted) in production.
DJANGO_DEBUG=True

# Comma-separated list of allowed hostnames (leave blank when DEBUG=True — auto-filled).
# Production example: DJANGO_ALLOWED_HOSTS=api.famelogistics.com,www.famelogistics.com
DJANGO_ALLOWED_HOSTS=

# Comma-separated trusted origins for CSRF. Required when DEBUG=False.
# Production example: CSRF_TRUSTED_ORIGINS=https://app.famelogistics.com,https://www.famelogistics.com
CSRF_TRUSTED_ORIGINS=

# Set to False in production to disable the Django admin at /admin/.
# Defaults to True when DEBUG=True, False when DEBUG=False.
DJANGO_ADMIN_ENABLED=True

# -----------------------------------------------------------------------------
# Django superuser (local dev seeding only — do not use in production)
# -----------------------------------------------------------------------------
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@famelogistics.com
DJANGO_SUPERUSER_PASSWORD=admin123

# -----------------------------------------------------------------------------
# CORS — origins allowed to make cross-site requests with credentials.
# Required in production (DEBUG=False). Comma-separated.
# Production example: CORS_ALLOWED_ORIGINS=https://app.famelogistics.com
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# -----------------------------------------------------------------------------
# AWS / Cloudflare R2 cloud storage (leave blank to use local/mock storage)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# R2 endpoint: https://<account-id>.r2.cloudflarestorage.com
# Leave blank for standard AWS S3.
AWS_S3_ENDPOINT_URL=
AWS_STORAGE_BUCKET_NAME=fms-documents
AWS_S3_REGION_NAME=auto
# Presigned URL lifetime in seconds (default: 3600 = 1 hour)
AWS_PRESIGNED_URL_EXPIRY=3600
